SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
GOOGLE_CLIENT_ID=

# Brain / knowledge graph (optional for local run)
# Leave empty to run locally: nodes use simple text extraction, no embeddings or vector search.
# Create at https://platform.openai.com/api-keys — no quotes; one line; restart the server after changing.
# If you still get 401, check Windows "Environment variables": a user/system OPENAI_API_KEY overrides
# this file unless the app loads with override (this project does). Prefer only one place for the key.
OPENAI_API_KEY=

# Handwriting OCR (vision): defaults to gpt-4o for best accuracy. Optional overrides:
# OCR_VISION_MODEL=gpt-4o
# OCR_IMAGE_MAX_SIDE=3072
# OCR_JPEG_QUALITY=90

PINECONE_API_KEY=
PINECONE_INDEX=atlus-brain
